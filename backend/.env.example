# 复制为 .env 后按需修改
# Docker Compose 映射主机 5433 时：
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5433/kling_story
# 本机 PostgreSQL 默认 5432 时把端口改为 5432

# DeepSeek（OpenAI 兼容 API）：https://platform.deepseek.com 申请密钥
DEEPSEEK_API_KEY=
# 可选：DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选：DEEPSEEK_MODEL=deepseek-chat

# Edge TTS 旁白（默认 zh-CN-XiaoxiaoNeural）
# EDGE_TTS_VOICE=zh-CN-YunxiNeural
# 可选：GENERATED_AUDIO_URL_PREFIX=/media/generated-audio
